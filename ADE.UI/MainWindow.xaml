<Window x:Class="ADE.UI.MainWindow"
        Icon="/Resources/ade.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADE - Ata Digital de Evidências"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        MinWidth="900"
        MinHeight="500"
        Background="#F0F4F8"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

	<Window.Resources>
		<DropShadowEffect x:Key="CardShadow" Color="#000000" Opacity="0.15" BlurRadius="20" ShadowDepth="5"/>
		<Style TargetType="Button">
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                Padding="12,10"
                                x:Name="ButtonBorder">
							<ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<ScrollViewer Grid.Row="0" Grid.RowSpan="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
			<Grid Margin="10">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

		<!-- CABEÇALHO COM GRADIENTE -->

		<Border Grid.Row="0"
                Padding="25"
                BorderThickness="0,0,0,3"
                BorderBrush="#0A3D7C"
                MinWidth="600">

			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
					<GradientStop Color="#0A3D7C" Offset="0"/>
					<GradientStop Color="#1565C0" Offset="0.5"/>
					<GradientStop Color="#1976D2" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>

			<Grid>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- Logo -->
				<Border Grid.Column="0"
                            Background="White"
                            CornerRadius="24"
                            Width="100"
                            Height="100"
                            Margin="0,0,25,0"
                            VerticalAlignment="Center"
                            Effect="{StaticResource CardShadow}">
						<Grid>
							<Image Source="pack://application:,,,/ADE.UI;component/Resources/logo.png"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
						</Grid>
					</Border>

					<StackPanel Grid.Column="1" VerticalAlignment="Center">

						<TextBlock
                            FontSize="32"
                            FontWeight="Bold"
                            Text="ATA DIGITAL DE EVIDÊNCIAS"
                            Foreground="White"
                            FontFamily="Segoe UI"/>

						<TextBlock
                            Name="CaseIdTextBlock"
                            FontSize="16"
                            Text="Caso Atual: Nenhum"
                            Foreground="White"
                            FontFamily="Segoe UI"
                            Margin="0,8,0,0"
                            Opacity="0.95"
                            FontWeight="SemiBold"/>

						<TextBlock
                            FontSize="12"
                            Text="Versão 1.0"
                            Foreground="White"
                            FontFamily="Segoe UI"
                            Margin="0,6,0,0"
                            Opacity="0.8"
                            FontWeight="Normal"/>

					</StackPanel>

					<Border Grid.Column="2"
                            Background="White"
                            CornerRadius="16"
                            Padding="25,15"
                            Margin="25,0,0,0"
                            VerticalAlignment="Center"
                            Effect="{StaticResource CardShadow}">

						<StackPanel>

							<TextBlock
                                FontWeight="Bold"
                                Text="STATUS"
                                FontSize="11"
                                Foreground="#0A3D7C"
                                FontFamily="Segoe UI"/>

							<TextBlock
                                Name="StatusTextBlock"
                                FontSize="20"
                                Text="AGUARDANDO"
                                FontWeight="SemiBold"
                                Foreground="#0A3D7C"
                                FontFamily="Segoe UI"
                                Margin="0,8,0,0"
                                TextOptions.TextFormattingMode="Display"
                                TextAlignment="Center"/>

						</StackPanel>

					</Border>

				</Grid>

		</Border>

		<!-- DADOS -->

		<Border Grid.Row="1"
                Margin="0,20,0,20"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E2E8F0"
                BorderThickness="2"
                Effect="{StaticResource CardShadow}">

			<Grid Margin="20,20,20,20">

				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0"
                           Text="DADOS DO PROCEDIMENTO"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#0A3D7C"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,20"/>

				<Grid Grid.Row="1">

					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="120" MinWidth="100"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="BO"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<TextBox Grid.Row="0"
                             Grid.Column="1"
                             Name="BoTextBox"
                             Height="40"
                             Padding="12,10"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             BorderBrush="#D1D9E6"
                             BorderThickness="2"
                             Margin="0,0,0,15"
                             Background="#F8FAFC"
                             CaretBrush="#0A3D7C"/>

					<TextBlock Grid.Row="1"
                               Text="Procedimento"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<TextBox Grid.Row="1"
                             Grid.Column="1"
                             Name="ProcedimentoTextBox"
                             Height="40"
                             Padding="12,10"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             BorderBrush="#D1D9E6"
                             BorderThickness="2"
                             Margin="0,0,0,15"
                             Background="#F8FAFC"
                             CaretBrush="#0A3D7C"/>

					<TextBlock Grid.Row="2"
                               Text="Unidade"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<TextBox Grid.Row="2"
                             Grid.Column="1"
                             Name="UnidadeTextBox"
                             Height="40"
                             Padding="12,10"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             BorderBrush="#D1D9E6"
                             BorderThickness="2"
                             Margin="0,0,0,15"
                             Background="#F8FAFC"
                             CaretBrush="#0A3D7C"/>

					<TextBlock Grid.Row="3"
                               Text="Responsável"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<TextBox Grid.Row="3"
                             Grid.Column="1"
                             Name="OfficerTextBox"
                             Height="40"
                             Padding="12,10"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             BorderBrush="#D1D9E6"
                             BorderThickness="2"
                             Margin="0,0,0,15"
                             Background="#F8FAFC"
                             CaretBrush="#0A3D7C"/>

					<TextBlock Grid.Row="4"
                               VerticalAlignment="Top"
                               Text="Observações"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2C3E50"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<TextBox Grid.Row="4"
                             Grid.Column="1"
                             Height="80"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Name="ObservacoesTextBox"
                             Padding="12,10"
                             FontSize="13"
                             FontFamily="Segoe UI"
                             BorderBrush="#D1D9E6"
                             BorderThickness="2"
                             VerticalScrollBarVisibility="Auto"
                             Background="#F8FAFC"
                             CaretBrush="#0A3D7C"/>

				</Grid>

			</Grid>

		</Border>

		<!-- CORPO -->

		<Border Grid.Row="2"
                Background="White"
                CornerRadius="16"
                BorderBrush="#E2E8F0"
                BorderThickness="2"
                Margin="0,0,0,20"
                MinHeight="400"
                Effect="{StaticResource CardShadow}">

			<Grid Margin="15,15,15,15">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="220" MinWidth="180" MaxWidth="300"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

			<!-- MENU -->

			<Border Grid.Column="0"
                    Background="#F8FAFC"
                    CornerRadius="12"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Margin="0,0,15,0">

				<Grid Margin="15,15,15,15">

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="OPERAÇÕES"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#0A3D7C"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

						<StackPanel>

							<Button Name="NovaColetaButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Nova Coleta"
                                    Click="NovaColeta_Click"
                                    Background="#0A3D7C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="AdicionarEvidenciaButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Adicionar Evidência"
                                    Click="AdicionarEvidencia_Click"
                                    Background="#2E7D32"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="CapturarTelaButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Capturar Tela"
                                    Click="CapturarTela_Click"
                                    Background="#00838F"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="CapturarMonitorButton"
									Height="40"
									Margin="0,0,0,8"
									Content="Capturar Monitor"
									Click="CapturarMonitor_Click"
                                    Background="#00838F"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="CapturarJanelaButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Capturar Janela"
                                    Click="CapturarJanela_Click"
                                    Background="#00838F"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="GerarRelatorioButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Gerar Relatório"
                                    Click="GerarRelatorio_Click"
                                    Background="#6A1B9A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="VerificarIntegridadeButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Verificar Integridade"
                                    Click="VerificarIntegridade_Click"
                                    Background="#E65100"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="ExportarTimelineButton"
                                    Height="40"
                                    Margin="0,0,0,8"
                                    Content="Exportar Timeline"
                                    Click="ExportarTimeline_Click"
                                    Background="#00695C"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

							<Button Name="ExportarCasoButton"
                                    Height="40"
                                    Margin="0,0,0,0"
                                    Content="Exportar Caso"
                                    Click="ExportarCaso_Click"
                                    Background="#4527A0"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    FontFamily="Segoe UI"
                                    Cursor="Hand"/>

						</StackPanel>

					</ScrollViewer>

				</Grid>

			</Border>

			<!-- EVIDÊNCIAS -->

			<Border Grid.Column="1"
                    Background="#F8FAFC"
                    CornerRadius="12"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

				<Grid Margin="15,15,15,15">

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Grid.Row="0"
                               Text="EVIDÊNCIAS COLETADAS"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#0A3D7C"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,15"/>

					<DataGrid Grid.Row="1"
                              Name="EvidenceGrid"
                              AutoGenerateColumns="False"
                              FontSize="13"
                              FontFamily="Segoe UI"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#F8FAFC"
                              RowBackground="White"
                              BorderBrush="#E2E8F0"
                              BorderThickness="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              MinWidth="400"
                              MinHeight="200"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              SelectionMode="Single"
                              IsReadOnly="True">

						<DataGrid.Columns>

							<DataGridTextColumn
                                Header="Arquivo"
                                Binding="{Binding FileName}"
                                Width="*"
                                MinWidth="150"
                                IsReadOnly="True"/>

							<DataGridTextColumn
                                Header="Método"
                                Binding="{Binding CollectionMethod}"
                                Width="*"
                                MinWidth="100"
                                IsReadOnly="True"/>

							<DataGridTextColumn
                                Header="Tipo"
                                Binding="{Binding EvidenceType}"
                                Width="*"
                                MinWidth="60"
                                IsReadOnly="True"/>

							<DataGridTextColumn
                                Header="Data"
                                Binding="{Binding CollectedAtUtc, StringFormat='dd/MM/yyyy HH:mm'}"
                                Width="*"
                                MinWidth="120"
                                IsReadOnly="True"/>

							<DataGridTextColumn
                                Header="SHA256"
                                Binding="{Binding Sha256}"
                                Width="*"
                                MinWidth="200"
                                IsReadOnly="True"/>

						</DataGrid.Columns>

					</DataGrid>

				</Grid>

			</Border>

			</Grid>
		</Border>
		</Grid>
		</ScrollViewer>

		<!-- RODAPÉ -->

		<StatusBar Grid.Row="3" Background="#0A3D7C" Foreground="White" Padding="15,8">

			<TextBlock Text="ADE 1.0 - Ata Digital de Evidências" FontSize="12" FontWeight="SemiBold"/>

		</StatusBar>

	</Grid>

</Window>