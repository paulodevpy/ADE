<Window x:Class="ADE.UI.SignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assinar Relatório" Height="220" Width="480" WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBox Name="PfxPathTextBox" Width="340" IsReadOnly="True" />
            <Button Content="Selecionar PFX" Width="110" Margin="8,0,0,0" Click="SelectPfx_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock VerticalAlignment="Center" Text="Senha:" Width="60" />
            <PasswordBox Name="PfxPasswordBox" Width="200" />
            <Button Content="Salvar" Width="100" Margin="8,0,0,0" Click="Save_Click" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Selecione um certificado digital A1 (ICP-Brasil) no formato .pfx e informe a senha. O sistema valida o certificado, a chave privada e a validade antes de prosseguir com a assinatura." TextWrapping="Wrap" />
    </Grid>

</Window>
